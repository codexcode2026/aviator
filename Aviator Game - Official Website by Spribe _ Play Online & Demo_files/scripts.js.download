(function($){
    $(document).ready(function(){
        jQuery(".mune1_icon").click(function(){
            jQuery(".close1_icon").show();
            jQuery(".mune1_icon").hide();
        });
        jQuery(".close1_icon").click(function(){
            jQuery(".mune1_icon").show();
            jQuery(".close1_icon").hide();
        });
        jQuery(".mune_icon_ img").click(function(){
            jQuery(".main_header_nav").slideToggle();
        });
        if(screen.width<992){
            jQuery(".header_nav ul li a").click(function(){
                jQuery(".main_header_nav").hide();
                jQuery(".close1_icon").hide();
                jQuery(".mune1_icon").show();
            });
        }
    });
})(jQuery);

document.addEventListener("DOMContentLoaded", function () {
    let today = new Date();
    
    let day = String(today.getDate()).padStart(2, "0");
    let month = String(today.getMonth() + 1).padStart(2, "0");
    let year = today.getFullYear();

    let formattedDate = `${day}.${month}.${year}`;
    
    let dateElement = document.querySelector("#update-date span");
    if (dateElement) {
        dateElement.textContent = formattedDate;
    } else {
        console.error("Element mit ID #update-date wurde nicht gefunden.");
    }
});

		function toggleDemo() {
			const demoContainer = document.getElementById('demo-container');
			const iframe = document.getElementById('demo-iframe');
			
			if (demoContainer.style.display === 'none') {
				// Show demo
				demoContainer.style.display = 'block';
				iframe.src = 'https://demo.spribe.io/launch/aviator?currency=ZAR&amp;lang=EN';
			} else {
				// Hide demo
				closeDemo();
			}
		}
		
		function closeDemo() {
			const demoContainer = document.getElementById('demo-container');
			const iframe = document.getElementById('demo-iframe');
			
			demoContainer.style.display = 'none';
			iframe.src = ''; // Stop loading
		}



