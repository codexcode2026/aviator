{
  "name": "aviator",
  "private": true,
  "version": "1.0.0",
  "description": "Aviator crash game — root workspace",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "test:ui": "playwright test --config ui-tests/playwright.config.ts",
    "test:ui:fast": "playwright test --config ui-tests/playwright.config.ts",
    "test:ui:slow": "cross-env SLOW_ONLY=1 playwright test --config ui-tests/playwright.config.ts",
    "test:ui:full": "cross-env FULL=1 playwright test --config ui-tests/playwright.config.ts",
    "test:ui:headed": "playwright test --config ui-tests/playwright.config.ts --headed",
    "test:ui:debug": "playwright test --config ui-tests/playwright.config.ts --debug",
    "test:ui:report": "playwright show-report ui-tests/report",
    "test:ui:visual": "cross-env VISUAL=1 playwright test --config ui-tests/playwright.config.ts --grep @visual",
    "test:ui:update-snapshots": "cross-env VISUAL=1 playwright test --config ui-tests/playwright.config.ts --grep @visual --update-snapshots",
    "test:ui:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "cross-env": "^7.0.3"
  }
}
